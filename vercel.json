{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data:;" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/tools", "destination": "/" },
    { "source": "/writing", "destination": "/" },
    { "source": "/about", "destination": "/" },
    { "source": "/resume", "destination": "/" },
    { "source": "/proof", "destination": "/" },
    { "source": "/contact", "destination": "/" }
  ]
}
